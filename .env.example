# ==========================================
# AI Tutor 环境配置
# 复制此文件为 .env 并填入实际值
# ==========================================

# HTTP 代理（访问 Google API 需要，如 clash/v2ray 等）
# PROXY_URL=http://127.0.0.1:7897
# HTTP_PROXY=http://127.0.0.1:7897

# Gemini API Keys (支持多个 Key 轮换，至少配置一个)
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_API_KEY_2=your_second_key_here
# GEMINI_API_KEY_3=your_third_key_here

# API 访问令牌（用于前端调用后端API的认证）
# 修改此值为复杂随机字符串，并在前端设置中配置相同值
API_TOKEN=change-me-to-a-random-string

# 允许的前端来源（逗号分隔），生产环境请改为实际域名
ALLOWED_ORIGINS=http://localhost:5173

# 数据保留天数（超过此天数的对话记录和错题将被自动清理）
DATA_RETENTION_DAYS=365

# AI 模型配置（可选，默认值见 config/index.js）
# EMBED_MODEL=gemini-embedding-2
# CHAT_MODEL=gemini-flash-lite-latest

# DeepSeek 备用 API（Gemini 不可用时自动降级）
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_API_URL=https://api.deepseek.com/v1
# DEEPSEEK_CHAT_MODEL=deepseek-v4-pro

# 服务器端口
PORT=3001

# 运行模式: development | production
NODE_ENV=production
